{
    "manifest_version": 3,
    "name": "Karakeep Social Media Button",
    "version": "1.0",
    "icons": {
        "16": "assets/icon-16.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.instagram.com/*",
                "*://*.pinterest.com/*"
            ],
            "js": [
                "content.js",
                "request.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/karakeep.svg"
            ],
            "matches": [
                "*://*.instagram.com/*",
                "*://*.pinterest.com/*"
            ]
        }
    ]
}